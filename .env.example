# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — it is NEVER committed and never travels with `git pull`.
# On the VPS: create .env.local by hand over SSH once, then leave it alone across deploys.

# --- Chatbot (Feature 1) ---
# Anthropic Console → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Cal.com API key → account Settings → Developer → API Keys (v2 API)
CAL_COM_API_KEY=
# The specific bookable event type ID the chatbot should offer.
CAL_COM_EVENT_TYPE_ID=

# --- Content pipeline (Feature 2) ---
# Shared secret the VPS crontab sends when it hits /api/internal/generate-draft.
# Generate any long random string, e.g.: openssl rand -hex 32
INTERNAL_CRON_SECRET=

# --- Email marketing (Feature 3) ---
# Resend dashboard → https://resend.com/api-keys
RESEND_API_KEY=
# Resend dashboard → Audiences → the target audience/list ID
RESEND_AUDIENCE_ID=
# Must be an address on a domain verified in Resend (Resend → Domains).
NEWSLETTER_FROM_EMAIL=
